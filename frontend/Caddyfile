{
    email {env.CADDY_EMAIL}
    default_sni serranito.acerohernan.com
}

serranito.acerohernan.com {
    root * /srv
    encode zstd gzip
    file_server

    header / {
      X-Frame-Options "SAMEORIGIN"
      X-Content-Type-Options "nosniff"
    }

    reverse_proxy /api/* http://api-rest:8080
    try_files {path} /index.html
}
